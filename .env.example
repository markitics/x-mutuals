# X (Twitter) app credentials — from https://console.x.com
# Copy this file to .env and fill in real values. Never commit .env.

# OAuth 1.0a consumer credentials (for owned-read pricing on your own followers)
X_CONSUMER_KEY=
X_SECRET_KEY=

# OAuth 2.0 credentials (for the "Sign in with X" web flow)
X_CLIENT_ID=
X_CLIENT_SECRET=

# App-only bearer token (for reading target's following list)
X_BEARER_TOKEN=

# Used to sign session cookies — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
